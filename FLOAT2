            f11b = Font(name='돋움', size=11, bold=True); f11n = Font(name='돋움', size=11)
            f10n = Font(name='돋움', size=10); f18b = Font(name='돋움', size=18, bold=True)
            ac = Alignment(horizontal='center', vertical='center', wrap_text=True)

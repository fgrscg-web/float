            "Grade_K": float(self.txt_grade_k.text()), "Z_btm": round(self.calc_z_btm, 2),
            "Z_top": round(self.calc_z_top, 2), "Act_FB": round(self.act_fb, 1),
            "Allow_FB": round(self.allow_fb, 1), "Shear": 0.0, "Pos_Shear": 'N/A',

                        if is_target and local_stress > self.max_mesh_stress:
                            self.max_mesh_stress = local_stress
                            self.max_mesh_coords = (piece.centroid.x, piece.centroid.y)
                            self.max_shell_q_idx = i

                self.shear_flows[i] = max_stress_for_poly

            # ===== 1D 추출 시작 =====
            progress.setLabelText("Step 1: Filtering noise...")
            
            # 수정사항 2: -1102는 500mm 이하 필터링
            filtered_1999 = filter_short_segments(calc_1999_raw, min_length=20)
            filtered_157 = filter_short_segments(calc_157, min_length=20)
            filtered_1102 = filter_short_segments(calc_1102_raw, min_length=500)
            
            progress.setLabelText("Step 2: Healing 1102...")
            healed_1102 = self.heal_1102_collinear(filtered_1102, threshold_gap=150)
            
            # 수정사항 1: 1999 곡선 그대로 사용 (병합 안 함)
            progress.setLabelText("Step 3: Processing 1999 layer...")
            lines_1999_final = []
            for line in filtered_1999:
                lines_1999_final.append({
                    'line': line,
                    'thickness': 10.0,
                    'type': '1999'
                })
            
            # 수정사항 4: 겹침 기반 매칭으로 전면 교체
            progress.setLabelText("Step 4: Matching parallel pairs (robust)...")
            pairs_157 = match_parallel_pairs_robust(filtered_157, max_distance=80)
            pairs_1102 = match_parallel_pairs_robust(healed_1102, max_distance=80)
            
            progress.setLabelText("Step 5: Generating centerlines...")
            centerlines_157 = [generate_centerline_from_pair(p[0], p[1], p[2]) for p in pairs_157]
            centerlines_1102 = [generate_centerline_from_pair(p[0], p[1], p[2]) for p in pairs_1102]
            
            for cl in centerlines_157:
                cl['type'] = '157'
            for cl in centerlines_1102:
                cl['type'] = '1102'
            
            progress.setLabelText("Step 6: Aligning to center mold...")
            all_internal_centerlines = centerlines_157 + centerlines_1102
            aligned_centerlines = align_adjacent_centerlines(all_internal_centerlines, angle_tol=3, dist_tol=50)
            
            progress.setLabelText("Step 7: Snapping - intersections...")
            all_centerlines = lines_1999_final + aligned_centerlines
            all_centerlines, int_nodes = create_intersection_nodes_and_trim(all_centerlines)
            
            progress.setLabelText("Step 8: Snapping - collinear...")
            all_centerlines, ext_nodes = connect_collinear_endpoints(all_centerlines, max_distance=100)
            
            # 수정사항 5: Ray casting 시 타겟 선분 두께 사용
            progress.setLabelText("Step 9: Snapping - ray casting...")
            all_centerlines, ray_nodes = raycast_open_nodes(all_centerlines, max_distance=100)
            
            progress.setLabelText("Step 10: Collecting nodes...")
            all_nodes_raw = []
            for cl in all_centerlines:
                all_nodes_raw.extend(list(cl['line'].coords))
            all_nodes_raw.extend(int_nodes)
            all_nodes_raw.extend(ext_nodes)
            all_nodes_raw.extend(ray_nodes)
            
            final_nodes = []
            for pt in all_nodes_raw:
                if not final_nodes or min(np.linalg.norm(np.array(pt) - np.array(fn)) for fn in final_nodes) > 1.0:
                    final_nodes.append(pt)
            
            self.centerlines = all_centerlines
            self.nodes = final_nodes
            
            self.calc_max_q_val = self.max_mesh_stress
            all_y = [pt[1] for p in self.calculated_polygons for pt in p.exterior.coords]
            y_max, y_min = max(all_y), min(all_y)
            self.calc_depth = (y_max - y_min) * 1e-3
            dist_top, dist_btm = y_max - self.calc_na_bl, self.calc_na_bl - y_min
            z_act_top_mm3 = self.calc_ixx / dist_top if dist_top != 0 else 1e-9
            self.calc_z_top, self.calc_z_btm = z_act_top_mm3 * 1e-9, (
                        self.calc_ixx / dist_btm * 1e-9) if dist_btm != 0 else 0
            self.act_fb = (abs(self.raw_swbm) * 9.80665 * 1e6) / z_act_top_mm3

            if self.max_shell_q_idx != -1:
                p_max = self.calculated_polygons[self.max_shell_q_idx]
                dx, dy = p_max.bounds[2] - p_max.bounds[0], p_max.bounds[3] - p_max.bounds[1]
                self.max_shell_thk = round(p_max.area / max(dy, dx, 1e-9), 1)

                if self.max_shell_q_idx < num_shell_seg:
                    loc_n = f"S{self.max_shell_q_idx + 1}"
                elif self.max_shell_q_idx < num_shell_seg * 2:
                    loc_n = f"S{self.max_shell_q_idx - num_shell_seg + 1} (Right)"
                else:
                    loc_n = "Internal Web"
                self.act_fs = self.max_mesh_stress / self.max_shell_thk if self.max_shell_thk > 0 else 0.0
                self.q_per_v = (self.max_mesh_stress / vy_n) if vy_n != 0 else 0.0
                self.max_Q = self.max_mesh_stress * self.calc_ixx / vy_n if vy_n != 0 else 0.0
            else:
                self.max_shell_thk = self.act_fs = self.q_per_v = self.max_Q = self.max_mesh_stress = 0.0
                loc_n = "N/A"

            res = f"--- Applied Loads ---\nS.W.B.M          : {self.raw_swbm:,.2f} tm\nShear Force      : {self.raw_shear:,.2f} t\n\n"
            res += f"--- Geometric Properties ---\nTotal Area       : {self.calc_total_area / 100.0:>10,.2f} cm^2\nInertia          : {self.calc_ixx * 1e-12:,.6e} m^4\nDepth            : {self.calc_depth:.3f} m\nDistance of N.A  : {self.calc_na_bl * 1e-3:.3f} m from B.L\nZact_btm         : {self.calc_z_btm:,.4f} m^3\nZact_top         : {self.calc_z_top:,.4f} m^3\n\n"
            res += f"--- Max Shear Flow Information ---\nLocation          : {loc_n} (X: {self.max_mesh_coords[0]:.0f}, Y: {self.max_mesh_coords[1]:.0f})\nPlate Thickness   : {self.max_shell_thk} mm\n1st Moment (Q)   : {self.max_Q * 1e-9:,.4f} m^3\nUnit Shear Flow  : {self.q_per_v * 1e3:,.6f} 1/m\nMax Shear Flow(q): {self.max_mesh_stress:.2f} N/mm\n"
            res += f"\n--- 1D Extraction Results ---\n"
            res += f"Total Centerlines: {len(self.centerlines)}\n"
            res += f"Total Nodes      : {len(self.nodes)}\n"
            
            self.base_report = res
            self.result_box.setText(self.base_report)
            self.is_calculated = True
            self.btn_eval.setEnabled(True)
            
            progress.setLabelText("Rendering UI...")
            progress.setMaximum(0)
            QApplication.processEvents()
            
            self.refresh_ui()

        except Exception as e:
            self.result_box.setText(f"Error: {e}\n{traceback.format_exc()}")
        finally:
            progress.close()

    def evaluate_strength(self):
        if not self.is_calculated: return
        try:
            k = float(self.txt_grade_k.text())
        except:
            k = 1.0
        self.allow_fs = 105 / k
        h_t = self.combo_hull.currentText()
        if self.combo_section.currentText() == "continuous section":
            self.allow_fb = 143 / k
        else:
            self.allow_fb = {"mild": 60, "H.T": 75, "H.T with BKT": 112}.get(h_t, 60)

        final_res = self.base_report + "\n--- Strength Check & Utilization ---\n"
        final_res += f"Material         : {self.combo_hull.currentText()}\n\n"
        final_res += f"Bending Stress   : {self.act_fb:.2f} / {self.allow_fb:.2f} N/mm2 ({self.act_fb / self.allow_fb * 100:.1f}%) [{'PASS' if self.act_fb <= self.allow_fb else 'FAIL'}]\n"
        final_res += f"Shear Stress     : {self.act_fs:.2f} / {self.allow_fs:.2f} N/mm2 ({self.act_fs / self.allow_fs * 100:.1f}%) [{'PASS' if self.act_fs <= self.allow_fs else 'FAIL'}]\n"
        self.result_box.setText(final_res)
        self.btn_save_frame.setEnabled(True)

    def save_current_frame(self):
        frame_name, ok = QInputDialog.getText(self, "Save Frame", "Enter Frame Name:", QLineEdit.EchoMode.Normal, "FR.")
        if not ok or not frame_name.strip(): return
        img_sec, img_shr = io.BytesIO(), io.BytesIO()
        self.fig1.savefig(img_sec, format='png', bbox_inches='tight', dpi=150)
        self.fig2.savefig(img_shr, format='png', bbox_inches='tight', dpi=150)
        loc_n = self.base_report.split("Location          : ")[1].split("\n")[
            0] if "Location" in self.base_report else "N/A"

        data = {
            "Frame": frame_name.strip(), "SWBM": self.raw_swbm, "Depth": round(self.calc_depth, 2),
            "NA": round(self.calc_na_bl * 1e-3, 2), "Ixx": round(self.calc_ixx * 1e-12, 2),
            "Grade_K": float(self.txt_grade_k.text()), "Z_btm": round(self.calc_z_btm, 2),
            "Z_top": round(self.calc_z_top, 2),
            "Act_FB": round(self.act_fb, 1), "Allow_FB": round(self.allow_fb, 1), "Shear": self.raw_shear,
            "Pos_Shear": loc_n, "Thk": self.max_shell_thk, "Unit_q": self.q_per_v * 1e3,
            "Act_FS": round(self.act_fs, 1),
            "Allow_FS": round(self.allow_fs, 1), "ImgSec": img_sec.getvalue(), "ImgShr": img_shr.getvalue()
        }
        self.saved_frames_data.append(data)
        self.update_history_list_ui()

    def update_history_list_ui(self):
        for i in reversed(range(self.history_list_layout.count())):
            w = self.history_list_layout.itemAt(i).widget()
            if w: w.deleteLater()
        for i, data in enumerate(self.saved_frames_data):
            f = QFrame()
            f.setStyleSheet("background: white; border: 1px solid #BDC3C7; border-radius: 4px; margin-bottom: 2px;")
            l = QHBoxLayout(f)
            l.setContentsMargins(5, 5, 5, 5)
            lbl_name = QLabel(f"📝 {data['Frame']}")
            lbl_name.setStyleSheet("font-weight:bold; border:none;")
            l.addWidget(lbl_name)
            l.addStretch()
            for btn_text, handler, enable in [("✏️", lambda chk=False, idx=i: self.rename_frame(idx), True),
                                              ("⬆️", lambda chk=False, idx=i: self.move_frame_up(idx), i > 0),
                                              ("⬇️", lambda chk=False, idx=i: self.move_frame_down(idx),
                                               i < len(self.saved_frames_data) - 1),
                                              ("❌", lambda chk=False, idx=i: self.delete_saved_frame(idx), True)]:
                btn = QPushButton(btn_text)
                btn.setFixedSize(24, 24)
                btn.setStyleSheet("border: none; background: transparent;")
                btn.setEnabled(enable)
                btn.clicked.connect(handler)
                l.addWidget(btn)
            self.history_list_layout.addWidget(f)

    def rename_frame(self, idx):
        n, ok = QInputDialog.getText(self, "Rename", "Frame Name:", QLineEdit.Normal,
                                     self.saved_frames_data[idx]['Frame'])
        if ok and n.strip(): self.saved_frames_data[idx]['Frame'] = n.strip(); self.update_history_list_ui()

    def move_frame_up(self, index):
        if index > 0: self.saved_frames_data.insert(index - 1,
                                                    self.saved_frames_data.pop(index)); self.update_history_list_ui()

    def move_frame_down(self, index):
        if index < len(self.saved_frames_data) - 1: self.saved_frames_data.insert(index + 1, self.saved_frames_data.pop(
            index)); self.update_history_list_ui()

    def delete_saved_frame(self, index):
        if 0 <= index < len(self.saved_frames_data): del self.saved_frames_data[index]; self.update_history_list_ui()


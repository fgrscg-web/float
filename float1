                ax1.fill(*poly.exterior.xy, color='blue', alpha=0.4)
                ax1.plot(*poly.exterior.xy, color='darkblue', lw=1)
            
            if hasattr(self, 'mesh_cells') and self.mesh_cells:
                q_abs = [cell['stress'] for cell in self.mesh_cells]
                vmax = max(q_abs) if q_abs and max(q_abs) > 0 else 1
                norm = matplotlib.colors.Normalize(vmin=0, vmax=vmax)
                cmap = cm.jet

                for cell in self.mesh_cells:
                    if cell['stress'] > vmax * 0.001:
                        geom = cell['geom']
                        color = cmap(norm(cell['stress']))
                        if geom.geom_type == 'Polygon':
                            ax2.fill(*geom.exterior.xy, color=color, alpha=0.7, edgecolor='none')
                        elif geom.geom_type == 'MultiPolygon':
                            for g in geom.geoms:
                                ax2.fill(*g.exterior.xy, color=color, alpha=0.7, edgecolor='none')

            # 수정사항 6: 레이어별 색상만 다르게, 두께는 단일 색상
            if hasattr(self, 'centerlines') and self.centerlines:
                for cl in self.centerlines:
                    line_obj = cl['line']
                    x, y = line_obj.xy
                    
                    if cl.get('type') == '1999':
                        color = '#FF00FF'
                    elif cl.get('type') == '157':
                        color = '#00FFFF'
                    elif cl.get('type') == '1102':
                        color = '#FFFF00'
                    else:
                        color = '#00FF00'
                    
                    ax2.plot(x, y, color=color, linewidth=2.5, alpha=0.9, zorder=10)

            if hasattr(self, 'nodes') and self.nodes:
                nx = [pt[0] for pt in self.nodes]
                ny = [pt[1] for pt in self.nodes]
                ax2.plot(nx, ny, 'ro', markersize=5, markeredgecolor='white', 
                        markeredgewidth=1, label=f'Nodes ({len(self.nodes)})', zorder=11)

            if hasattr(self, 'max_mesh_coords') and self.max_mesh_stress > 0:
                ax2.plot(self.max_mesh_coords[0], self.max_mesh_coords[1],
                         'r*', markersize=18, markeredgecolor='yellow', 
                         markeredgewidth=2, label="Max Stress", zorder=12)

            self.fig2.colorbar(cm.ScalarMappable(norm=norm, cmap=cmap), ax=ax2, label="Stress (N/mm²)")
            ax2.legend(loc="upper right", fontsize=8)

        else:
            if self.raw_1999_lines:
                for ls in self.raw_1999_lines: ax1.plot(*ls.xy, color='black', lw=1.5)

            for i, l in enumerate(self.left_1999_segments):
                ax1.text(l.centroid.x, l.centroid.y, f"S{i + 1}", fontsize=10, fontweight='bold', ha='center',
                         va='center', bbox=dict(facecolor='white', alpha=0.7, edgecolor='none'))

        for i in range(len(self.left_1999_segments)):
            f = QFrame()
            r = QHBoxLayout(f)
            f.setStyleSheet("border-left: 4px solid #2E86C1; background: #FDFEFE; margin-bottom: 2px;")
            r.addWidget(QLabel(f"S{i + 1}:"))
            r.addStretch()
            edit = QLineEdit(saved[i] if i < len(saved) else "10")
            edit.setFixedWidth(self.field_width)
            edit.setStyleSheet(self.input_style)
            r.addWidget(edit)
            self.thickness_layout.addWidget(f)
            self.shell_thickness_inputs.append(edit)

        for ax in [ax1, ax2]:
            ax.set_aspect('equal')
            ax.grid(True, lw=0.3, alpha=0.5)
            ax.xaxis.set_major_formatter(FuncFormatter(lambda x, pos: f"{-x:g}"))

        self.can1.draw()
        self.can2.draw()

if __name__ == "__main__":
    app = QApplication(sys.argv)
    win = UltimateShipAnalyzer()
    win.show()
    sys.exit(app.exec())

    def _extract_pts(self, e, scale):
        try:
            if e.dxftype() == 'LINE':
                return [(e.dxf.start.x * scale, e.dxf.start.y * scale), (e.dxf.end.x * scale, e.dxf.end.y * scale)]
            elif e.dxftype() in ('LWPOLYLINE', 'POLYLINE'):
                return [(p[0] * scale, p[1] * scale) for p in e.get_points()]
        except:
            return None
        return None

    def heal_1102_collinear(self, lines_1102, threshold_gap=150.0):
        if not lines_1102: return []
        new_bridges = []
        groups = {}
        for l in lines_1102:
            c = list(l.coords)
            p1, p2 = np.array(c[0]), np.array(c[-1])
            v = p2 - p1
            L = np.linalg.norm(v)
            if L < 1e-6: continue
            ang = np.degrees(np.arctan2(v[1], v[0])) % 180.0
            ang_key = round(ang, 0)
            theta = np.radians(ang_key)
            rho = -p1[0] * np.sin(theta) + p1[1] * np.cos(theta)
            rho_key = round(rho / 10.0) * 10.0
            key = (ang_key, rho_key)
            if key not in groups: groups[key] = []
            groups[key].append((l, p1, p2))

        for (ang_key, rho_key), group in groups.items():
            if len(group) < 2: continue
            dir_vec = np.array([np.cos(np.radians(ang_key)), np.sin(np.radians(ang_key))])
            segs = sorted([(np.dot(p1, dir_vec), np.dot(p2, dir_vec), p1, p2) for _, p1, p2 in group],
                          key=lambda x: min(x[0], x[1]))
            for i in range(len(segs) - 1):
                p_end = segs[i][2] if segs[i][0] > segs[i][1] else segs[i][3]
                p_next_start = segs[i + 1][3] if segs[i + 1][0] > segs[i + 1][1] else segs[i + 1][2]
                gap_dist = np.linalg.norm(p_next_start - p_end)
                if 0.1 < gap_dist <= threshold_gap:
                    new_bridges.append(LineString([tuple(p_end), tuple(p_next_start)]))
        return lines_1102 + new_bridges

    def heal_157_segments(self, lines_157, lines_1999, threshold_gap=150.0):
        if not lines_157: return []
        lines = lines_157 + lines_1999
        healed = list(lines_157)
        new_bridges = []
        groups = {}
        for l in lines:
            p1, p2 = np.array(l.coords[0]), np.array(l.coords[-1])
            v = p2 - p1
            L = np.linalg.norm(v)
            if L < 1e-6: continue
            ang = np.degrees(np.arctan2(v[1], v[0])) % 180.0
            ang_key = round(ang, 1)
            theta = np.radians(ang_key)
            rho = -p1[0] * np.sin(theta) + p1[1] * np.cos(theta)
            key = (ang_key, round(rho, 0))
            if key not in groups: groups[key] = []
            groups[key].append((l, p1, p2))

        for (ang, rho), group in groups.items():
            dir_vec = np.array([np.cos(np.radians(ang)), np.sin(np.radians(ang))])
            segs = sorted([(np.dot(p1, dir_vec), np.dot(p2, dir_vec), p1, p2) for _, p1, p2 in group],
                          key=lambda x: min(x[0], x[1]))
            for i in range(len(segs) - 1):
                p_end = segs[i][2] if segs[i][0] > segs[i][1] else segs[i][3]
                p_next_start = segs[i + 1][3] if segs[i + 1][0] > segs[i + 1][1] else segs[i + 1][2]
                if 0 < np.linalg.norm(p_next_start - p_end) <= threshold_gap:
                    new_bridges.append(LineString([tuple(p_end), tuple(p_next_start)]))

        open_info = []
        for l in lines:
            c = list(l.coords)
            ps, pe = np.array(c[0]), np.array(c[-1])
            v_s = (ps - np.array(c[1]) if len(c) > 1 else ps - pe)
            v_e = (pe - np.array(c[-2]) if len(c) > 1 else pe - ps)
            open_info.append(((round(ps[0], 3), round(ps[1], 3)), ps, v_s / (np.linalg.norm(v_s) + 1e-9), l))
            open_info.append(((round(pe[0], 3), round(pe[1], 3)), pe, v_e / (np.linalg.norm(v_e) + 1e-9), l))

        connected = set()
        for i in range(len(open_info)):
            r1, p1, d1, l1 = open_info[i]
            if r1 in connected: continue
            best_j, min_d = -1, float('inf')
            for j in range(len(open_info)):
                if i == j or open_info[j][0] in connected or l1 is open_info[j][3]: continue
                r2, p2, d2, _ = open_info[j]
                gap_v = p2 - p1
                dist = np.linalg.norm(gap_v)
                if 1.0 < dist <= 150.0 and np.dot(d1, gap_v / dist) > -0.5 and np.dot(d2, -gap_v / dist) > -0.5:
                    if dist < min_d: min_d = dist; best_j = j
            if best_j != -1:
                new_bridges.append(LineString([tuple(p1), tuple(open_info[best_j][1])]))
                connected.update([r1, open_info[best_j][0]])

        final_open = [p for r, p, d, l in open_info if r not in connected and l not in lines_1999]
        if final_open and lines_1999:
            all_target = unary_union(healed + new_bridges + lines_1999)
            for p in final_open:
                nt = nearest_points(Point(p), all_target)[1]
                if 1.0 < Point(p).distance(nt) <= 100.0:
                    new_bridges.append(LineString([tuple(p), (nt.x, nt.y)]))

        return healed + new_bridges

    def generate_outward_thickness(self, line, thickness):
        try:
            coords = list(line.coords)
            p1, p2 = np.array(coords[0]), np.array(coords[-1])
            v = p2 - p1
            length = np.linalg.norm(v)
            if length == 0: return line.buffer(thickness / 2.0)
            nx, ny = -(v[1] / length), v[0] / length
            cx, cy = self.hull_centroid.x, self.hull_centroid.y
            mx, my = (p1[0] + p2[0]) / 2.0, (p1[1] + p2[1]) / 2.0
            if (nx * (mx - cx) + ny * (my - cy)) < 0: nx, ny = -nx, -ny
            new_coords = coords + [(p[0] + nx * thickness, p[1] + ny * thickness) for p in reversed(coords)]
            return Polygon(new_coords)
        except:
            return line.buffer(thickness / 2.0)

    def apply_original_algorithm(self, target_lines, shell_lines, ext, perp, max_a):
        if not target_lines: return []
        all_l = target_lines + shell_lines
        ends_dict = {}
        for l in all_l:
            for pt in [l.coords[0], l.coords[-1]]:
                p_rnd = (round(pt[0], 3) + 0.0, round(pt[1], 3) + 0.0)
                ends_dict[p_rnd] = ends_dict.get(p_rnd, 0) + 1
        ends = {k for k, v in ends_dict.items() if v == 1}

        ext_l, p_lines = [], []
        for l in all_l:
            c = list(l.coords)
            p_s, p_n = np.array(c[0]), np.array(c[1])
            p_l, p_p = np.array(c[-1]), np.array(c[-2])

            p_s_rnd = (round(p_s[0], 3) + 0.0, round(p_s[1], 3) + 0.0)
            p_l_rnd = (round(p_l[0], 3) + 0.0, round(p_l[1], 3) + 0.0)

            if p_s_rnd in ends:
                diff = p_s - p_n
                norm = np.linalg.norm(diff) + 1e-9
                v_s = diff / norm
                c[0] = tuple(p_s + v_s * ext)
                n = np.array([-v_s[1], v_s[0]])
                p_lines.append(LineString([tuple(p_s + n * perp), p_s, tuple(p_s - n * perp)]))

            if p_l_rnd in ends:
                diff = p_l - p_p
                norm = np.linalg.norm(diff) + 1e-9
                v_e = diff / norm
                c[-1] = tuple(p_l + v_e * ext)
                n = np.array([-v_e[1], v_e[0]])
                p_lines.append(LineString([tuple(p_l + n * perp), p_l, tuple(p_l - n * perp)]))

            ext_l.append(LineString(c))

        f_net = unary_union(ext_l + p_lines + shell_lines)
        c_polys = list(polygonize(f_net))
        return [p for p in c_polys if 1e-3 < p.area < max_a]

    def load_and_process_dxf(self):
        fname, _ = QFileDialog.getOpenFileName(self, 'Select DXF File', '', 'DXF files (*.dxf)')
        if not fname: return
        self.reset_analysis_data()
        self.result_box.clear()
        self.current_dxf_path = fname
        try:
            scale = float(self.txt_scale.text())
            try:
                doc = ezdxf.readfile(fname, encoding='utf-8')
            except Exception:
                doc = ezdxf.readfile(fname, encoding='cp949')
                
            msp = doc.modelspace()
            active_layers = {l.dxf.name for l in doc.layers if l.is_on() and not l.is_frozen()}
            t_1999, t_minus1204 = [], []
            t_layers = {"-1102": [], "157": [], "6001": [], "7001": [], "9001": []}

            for e in msp:
                layer = e.dxf.layer.strip()
                if layer not in active_layers: continue
                pts = self._extract_pts(e, scale)
                if not pts or len(pts) < 2: continue
                ls = LineString(pts)
                if layer == "1999":
                    t_1999.append(ls)
                elif layer == "-1204":
                    t_minus1204.append(ls)
                elif layer in t_layers:
                    t_layers[layer].append(ls)

            if t_1999:
                u_1999 = unary_union(t_1999)
                self.cx, self.cy_base = u_1999.centroid.x, u_1999.bounds[1]
            else:
                self.cx = self.cy_base = 0.0

            shift = lambda ls: LineString([(p[0] - self.cx, p[1] - self.cy_base) for p in ls.coords])
            self.raw_1999_lines = [shift(ls) for ls in t_1999]
            self.lines_minus1204 = [shift(ls) for ls in t_minus1204]
            
            m_1999 = unary_union(self.raw_1999_lines)
            self.hull_centroid = m_1999.centroid
            cutters = [LineString([tuple(np.array(c.coords[0]) - 20), tuple(np.array(c.coords[-1]) + 20)]) for c in self.lines_minus1204]
            split_res = split(m_1999, unary_union(cutters)) if cutters else m_1999
            pieces = list(split_res.geoms) if hasattr(split_res, 'geoms') else [split_res]
            self.left_1999_segments = sorted([g for g in pieces if g.centroid.x <= 0.1 and g.length > 0.1],
                                             key=lambda s: (-round(s.centroid.y, 2), s.centroid.x))

            self.lines_1102_raw = [shift(ls) for ls in t_layers["-1102"]]
            self.lines_157 = [shift(ls) for ls in t_layers["157"]]
            self.lines_6001 = [shift(ls) for ls in t_layers["6001"]]
            self.lines_7001 = [shift(ls) for ls in t_layers["7001"]]
            self.lines_9001 = [shift(ls) for ls in t_layers["9001"]]
            self.refresh_ui()
            self.result_box.append(f"✅ Successfully loaded: {os.path.basename(fname)}")
        except Exception as e:
            self.result_box.setText(f"❌ Load Error Detailed:\n{traceback.format_exc()}")

    def calculate_total_inertia(self):
        progress = QProgressDialog("Complete 1D Extraction...", "Cancel", 0, 100, self)
        progress.setWindowTitle("Processing")
        progress.setWindowModality(Qt.WindowModal)
        progress.setAutoClose(False)
        progress.show()
        QApplication.processEvents()

        def filter_short_segments(lines, min_length=20.0):
            return [l for l in lines if l.length >= min_length]
        
        def perpendicular_distance(point, line_start, line_end):
            p = np.array(point)
            a = np.array(line_start)
            b = np.array(line_end)
            
            ab = b - a
            ab_len = np.linalg.norm(ab)
            if ab_len < 1e-9:
                return np.linalg.norm(p - a)
            
            ab_unit = ab / ab_len
            ap = p - a
            proj_len = np.dot(ap, ab_unit)
            
            if proj_len < 0:
                return np.linalg.norm(p - a)
            elif proj_len > ab_len:
                return np.linalg.norm(p - b)
            else:
                proj_point = a + proj_len * ab_unit
                return np.linalg.norm(p - proj_point)
        
        def match_parallel_pairs_robust(lines, max_distance=80.0):
            """겹침 기반 평행 선분 매칭 - 중앙 걸친 부재 완벽 처리"""
            if not lines: return []
            
            potential_pairs = []
            
            for i, line1 in enumerate(lines):
                c1 = list(line1.coords)
                p1_start, p1_end = np.array(c1[0]), np.array(c1[-1])
                v1 = p1_end - p1_start
                len1 = np.linalg.norm(v1)
                if len1 < 1e-6: continue
                
                angle1 = np.degrees(np.arctan2(v1[1], v1[0])) % 180
                v1_unit = v1 / len1
                
                for j, line2 in enumerate(lines):
                    if i >= j: continue
                    
                    c2 = list(line2.coords)
                    p2_start, p2_end = np.array(c2[0]), np.array(c2[-1])
                    v2 = p2_end - p2_start
                    len2 = np.linalg.norm(v2)
                    if len2 < 1e-6: continue
                    
                    angle2 = np.degrees(np.arctan2(v2[1], v2[0])) % 180
                    angle_diff = min(abs(angle1 - angle2), 180 - abs(angle1 - angle2))
                    
                    if angle_diff > 5:
                        continue
                    
                    d1 = perpendicular_distance(p2_start, p1_start, p1_end)
                    d2 = perpendicular_distance(p2_end, p1_start, p1_end)
                    avg_dist = (d1 + d2) / 2.0
                    
                    if avg_dist > max_distance:
                        continue
                    
                    proj1_start = 0
                    proj1_end = len1
                    proj2_start = np.dot(p2_start - p1_start, v1_unit)
                    proj2_end = np.dot(p2_end - p1_start, v1_unit)
                    
                    if proj2_start > proj2_end:
                        proj2_start, proj2_end = proj2_end, proj2_start
                    
                    overlap_start = max(proj1_start, proj2_start)
                    overlap_end = min(proj1_end, proj2_end)
                    
                    if overlap_start < overlap_end - 1e-3:
                        potential_pairs.append({
                            'line1': line1,
                            'line2': line2,
                            'overlap_start': overlap_start,
                            'overlap_end': overlap_end,
                            'distance': avg_dist,
                            'v1_unit': v1_unit,
                            'p1_start': p1_start
                        })
            
            pairs = []
            for pair_info in potential_pairs:
                seg1_start = pair_info['p1_start'] + pair_info['v1_unit'] * pair_info['overlap_start']
                seg1_end = pair_info['p1_start'] + pair_info['v1_unit'] * pair_info['overlap_end']
                
                c2 = list(pair_info['line2'].coords)
                closest_points = []
                for pt in [np.array(c2[0]), np.array(c2[-1])]:
                    proj = np.dot(pt - pair_info['p1_start'], pair_info['v1_unit'])
                    if pair_info['overlap_start'] <= proj <= pair_info['overlap_end']:
                        closest_points.append(pt)
                
                if len(closest_points) >= 2:
                    seg2_start, seg2_end = closest_points[0], closest_points[1]
                else:
                    seg2_start = np.array(c2[0])
                    seg2_end = np.array(c2[-1])
                
                pairs.append((
                    LineString([tuple(seg1_start), tuple(seg1_end)]),
                    LineString([tuple(seg2_start), tuple(seg2_end)]),
                    pair_info['distance']
                ))
            
            return pairs
        
        def generate_centerline_from_pair(line1, line2, distance):
            c1 = list(line1.coords)
            c2 = list(line2.coords)
            
            center_coords = []
            for i in range(max(len(c1), len(c2))):
                p1 = np.array(c1[min(i, len(c1)-1)])
                p2 = np.array(c2[min(i, len(c2)-1)])
                center = (p1 + p2) / 2.0
                center_coords.append(tuple(center))
            
            centerline = LineString(center_coords) if len(center_coords) >= 2 else line1
            
            vec = np.array(centerline.coords[-1]) - np.array(centerline.coords[0])
            angle = np.degrees(np.arctan2(vec[1], vec[0])) % 180
            
            is_horiz = (angle < 3 or angle > 177)
            is_vert = (87 < angle < 93)
            
            if is_horiz or is_vert:
                thickness = distance
            else:
                coords = list(centerline.coords)
                mid_idx = len(coords) // 2
                
                dists = []
                for pt in [coords[0], coords[mid_idx], coords[-1]]:
                    d1 = perpendicular_distance(pt, c1[0], c1[-1])
                    d2 = perpendicular_distance(pt, c2[0], c2[-1])
                    dists.append((d1 + d2) / 2.0)
                
                thickness = np.mean(dists)
            
            thickness = round(thickness * 2) / 2.0
            
            if is_horiz:
                orientation = 'horizontal'
            elif is_vert:
                orientation = 'vertical'
            else:
                orientation = 'diagonal'
            
            return {
                'line': centerline,
                'thickness': thickness,
                'orientation': orientation,
                'angle': angle
            }
        
        def align_adjacent_centerlines(centerlines, angle_tol=3, dist_tol=50):
            if not centerlines: return centerlines
            
            groups = {'horizontal': [], 'vertical': [], 'diagonal': []}
            for cl in centerlines:
                groups[cl['orientation']].append(cl)
            
            aligned = []
            
            for orient, items in groups.items():
                if not items:
                    continue
                
                clusters = []
                for item in items:
                    coords = list(item['line'].coords)
                    endpoints = [np.array(coords[0]), np.array(coords[-1])]
                    
                    added = False
                    for cluster in clusters:
                        for ep_item in cluster['items']:
                            ep_coords = list(ep_item['line'].coords)
                            ep_points = [np.array(ep_coords[0]), np.array(ep_coords[-1])]
                            
                            for ep1 in endpoints:
                                for ep2 in ep_points:
                                    if np.linalg.norm(ep1 - ep2) <= dist_tol:
                                        ang_diff = min(abs(cluster['avg_angle'] - item['angle']),
                                                      180 - abs(cluster['avg_angle'] - item['angle']))
                                        if ang_diff <= angle_tol:
                                            cluster['items'].append(item)
                                            cluster['avg_angle'] = np.mean([x['angle'] for x in cluster['items']])
                                            added = True
                                            break
                                if added: break
                            if added: break
                        if added: break
                    
                    if not added:
                        clusters.append({'avg_angle': item['angle'], 'items': [item]})
                
                for cluster in clusters:
                    if len(cluster['items']) == 1:
                        aligned.append(cluster['items'][0])
                    else:
                        avg_angle = cluster['avg_angle']
                        theta = np.radians(avg_angle)
                        
                        rhos = []
                        for item in cluster['items']:
                            coords = list(item['line'].coords)
                            for pt in coords:
                                p = np.array(pt)
                                rho = -p[0]*np.sin(theta) + p[1]*np.cos(theta)
                                rhos.append(rho)
                        avg_rho = np.mean(rhos)
                        
                        normal = np.array([-np.sin(theta), np.cos(theta)])
                        
                        for item in cluster['items']:
                            coords = list(item['line'].coords)
                            projected = []
                            for pt in coords:
                                p = np.array(pt)
                                dist = np.dot(p, normal) - avg_rho
                                proj_p = p - dist * normal
                                projected.append(tuple(proj_p))
                            
                            aligned.append({
                                'line': LineString(projected),
                                'thickness': item['thickness'],
                                'orientation': item['orientation'],
                                'angle': avg_angle
                            })
            
            return aligned
        
        def line_segment_intersection(p1, p2, p3, p4):
            x1, y1 = p1
            x2, y2 = p2
            x3, y3 = p3
            x4, y4 = p4
            
            denom = (x1-x2)*(y3-y4) - (y1-y2)*(x3-x4)
            if abs(denom) < 1e-9:
                return None
            
            t = ((x1-x3)*(y3-y4) - (y1-y3)*(x3-x4)) / denom
            u = -((x1-x2)*(y1-y3) - (y1-y2)*(x1-x3)) / denom
            
            if 0 <= t <= 1 and 0 <= u <= 1:
                x = x1 + t*(x2-x1)
                y = y1 + t*(y2-y1)
                return (x, y)
            return None
        
        def create_intersection_nodes_and_trim(centerlines):
            intersection_nodes = []
            trimmed_lines = []
            
            for i, cl1 in enumerate(centerlines):
                coords1 = list(cl1['line'].coords)
                line_intersections = []
                
                for j, cl2 in enumerate(centerlines):
                    if i == j: continue
                    
                    coords2 = list(cl2['line'].coords)
                    
                    for k1 in range(len(coords1) - 1):
                        for k2 in range(len(coords2) - 1):
                            int_pt = line_segment_intersection(
                                coords1[k1], coords1[k1+1],
                                coords2[k2], coords2[k2+1]
                            )
                            if int_pt:
                                if (np.linalg.norm(np.array(int_pt) - np.array(coords1[k1])) > 1e-3 and
                                    np.linalg.norm(np.array(int_pt) - np.array(coords1[k1+1])) > 1e-3):
                                    line_intersections.append(int_pt)
                                    intersection_nodes.append(int_pt)
                
                if line_intersections:
                    start = np.array(coords1[0])
                    sorted_ints = sorted(line_intersections, 
                                        key=lambda p: np.linalg.norm(np.array(p) - start))
                    
                    all_points = [coords1[0]] + sorted_ints + [coords1[-1]]
                    for k in range(len(all_points) - 1):
                        if np.linalg.norm(np.array(all_points[k]) - np.array(all_points[k+1])) > 1e-3:
                            trimmed_lines.append({
                                'line': LineString([all_points[k], all_points[k+1]]),
                                'thickness': cl1['thickness'],
                                'type': cl1.get('type', 'internal')
                            })
                else:
                    trimmed_lines.append(cl1)
            
            return trimmed_lines, intersection_nodes
        
        def connect_collinear_endpoints(centerlines, max_distance=100):
            new_bridges = []
            
            endpoints = []
            for i, cl in enumerate(centerlines):
                coords = list(cl['line'].coords)
                if len(coords) < 2: continue
                
                p_start = np.array(coords[0])
                p_end = np.array(coords[-1])
                
                v_start = p_start - np.array(coords[1]) if len(coords) > 1 else np.array([0, 0])
                v_end = p_end - np.array(coords[-2]) if len(coords) > 1 else np.array([0, 0])
                
                if np.linalg.norm(v_start) > 1e-6:
                    endpoints.append({
                        'pt': p_start,
                        'vec': v_start / np.linalg.norm(v_start),
                        'thickness': cl['thickness'],
                        'idx': i
                    })
                
                if np.linalg.norm(v_end) > 1e-6:
                    endpoints.append({
                        'pt': p_end,
                        'vec': v_end / np.linalg.norm(v_end),
                        'thickness': cl['thickness'],
                        'idx': i
                    })
            
            open_endpoints = []
            for i, ep1 in enumerate(endpoints):
                is_open = True
                for j, ep2 in enumerate(endpoints):
                    if i == j: continue
                    if np.linalg.norm(ep1['pt'] - ep2['pt']) < 10:
                        is_open = False
                        break
                if is_open:
                    open_endpoints.append(ep1)
            
            matched = set()
            for i, ep1 in enumerate(open_endpoints):
                if i in matched: continue
                
                best_match = None
                best_dist = float('inf')
                best_j = -1
                
                for j, ep2 in enumerate(open_endpoints):
                    if i == j or j in matched: continue
                    
                    gap = ep2['pt'] - ep1['pt']
                    dist = np.linalg.norm(gap)
                    
                    if 1 < dist <= max_distance:
                        gap_dir = gap / dist
                        dot1 = np.dot(ep1['vec'], gap_dir)
                        dot2 = np.dot(ep2['vec'], -gap_dir)
                        
                        if dot1 > 0.9 and dot2 > 0.9:
                            if dist < best_dist:
                                best_dist = dist
                                best_match = ep2
                                best_j = j
                
                if best_match:
                    mid_pt = (ep1['pt'] + best_match['pt']) / 2.0
                    
                    new_bridges.append({
                        'line': LineString([tuple(ep1['pt']), tuple(mid_pt)]),
                        'thickness': ep1['thickness'],
                        'type': 'bridge'
                    })
                    new_bridges.append({
                        'line': LineString([tuple(mid_pt), tuple(best_match['pt'])]),
                        'thickness': best_match['thickness'],
                        'type': 'bridge'
                    })
                    
                    matched.add(i)
                    matched.add(best_j)
            
            return centerlines + new_bridges, []
        
